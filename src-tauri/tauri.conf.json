{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "桌面爬宠学习计时器",
  "version": "0.1.0",
  "identifier": "com.codex.study-pet-timer",
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "桌面爬宠学习计时器",
        "width": 228,
        "height": 272,
        "minWidth": 228,
        "minHeight": 272,
        "maximizable": false,
        "minimizable": false,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": false,
        "shadow": true,
        "visible": true,
        "focus": true
      }
    ],
    "security": {
      "csp": null,
      "capabilities": [
        {
          "identifier": "desktop-widget-window",
          "description": "Allows the main desktop widget window to resize, move and stay on top.",
          "windows": ["main"],
          "permissions": [
            "core:default",
            "core:window:default",
            "core:window:allow-set-position",
            "core:window:allow-set-size",
            "core:window:allow-start-dragging",
            "core:window:allow-set-always-on-top"
          ]
        }
      ]
    }
  },
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
